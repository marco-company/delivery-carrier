<odoo>

  <record id="view_laposte_fr_carrier_account_form" model="ir.ui.view">
    <field name="model">carrier.account</field>
    <field name="inherit_id" ref="delivery_carrier_account.carrier_account_view_form" />
    <field name="arch" type="xml">
      <field name="password" position="after">
        <field
                    name="laposte_fr_file_format"
                    attrs="{'invisible': [('delivery_type', '!=', 'laposte_fr')], 'required': [('delivery_type', '=', 'laposte_fr')]}"
                />
      </field>
    </field>
  </record>

</odoo>
